# Movie Analyzer — Environment Variables
# Copy to .env and fill in as needed.

# ── Whisper ──────────────────────────────────────────────────────────────────
WHISPER_MODEL=base           # tiny | base | small | medium | large
WHISPER_LANGUAGE=            # leave blank for auto-detect

# ── BLIP-2 Scene Captioning ───────────────────────────────────────────────────
BLIP2_MODEL=Salesforce/blip2-opt-2.7b   # or blip2-flan-t5-xl (smaller)
BLIP2_DEVICE=auto                        # auto | cuda | cpu

# ── Local LLM ─────────────────────────────────────────────────────────────────
LLM_BACKEND=auto             # auto | ollama | transformers | none
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b     # or mistral:7b for better quality
TRANSFORMERS_LLM_MODEL=microsoft/Phi-3-mini-4k-instruct

# ── Face Detection ────────────────────────────────────────────────────────────
FACE_BACKEND=deepface        # deepface (default)

# ── TTS ───────────────────────────────────────────────────────────────────────
TTS_ENGINE=coqui             # coqui (local) | gtts (Google, needs internet)

# ── Parallel Workers ──────────────────────────────────────────────────────────
IO_WORKERS=8
CPU_WORKERS=4

# ── Optional Cloud AI (only needed with --cloud-ai flag) ──────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
